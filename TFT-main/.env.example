# APEX Paper Trading - Minimal Configuration
# Copy to .env and fill in real credentials before running.
# Full reference: .env.template

# =============================================
# REQUIRED: API Keys
# =============================================
POLYGON_API_KEY=your_polygon_api_key_here
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER_API_KEY=your_alpaca_paper_api_key_here
ALPACA_PAPER_SECRET_KEY=your_alpaca_paper_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# =============================================
# REQUIRED: PostgreSQL
# =============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tft_trading
DB_USER=trading_user
DB_PASSWORD=your_secure_password_here

# Also used by training scripts
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tft_trading
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=your_secure_password_here

# =============================================
# OPTIONAL: Redis (for circuit breaker)
# =============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================
# OPTIONAL: Notifications
# =============================================
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL_HERE

# =============================================
# Paper Trading Settings
# =============================================
PAPER_TRADING_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,JPM,BAC,XOM
PAPER_FX_PAIRS=EURUSD,GBPUSD,USDJPY,AUDUSD,USDCAD,USDCHF
PAPER_SCHEDULE_HOUR=10
PAPER_SCHEDULE_MINUTE=0
PAPER_INITIAL_CAPITAL=100000
TRADING_MODE=paper

# =============================================
# Enable Strategies (all disabled by default)
# =============================================
STRATEGY_MOMENTUM_ENABLED=false
STRATEGY_STATARB_ENABLED=false
STRATEGY_MEAN_REVERSION_ENABLED=false
STRATEGY_SECTOR_ROTATION_ENABLED=false
STRATEGY_FX_ENABLED=false
STRATEGY_FX_MOMENTUM_ENABLED=false
STRATEGY_FX_VOL_BREAKOUT_ENABLED=false
STRATEGY_KRONOS_ENABLED=false
STRATEGY_DEEP_SURROGATES_ENABLED=false
STRATEGY_TDGF_ENABLED=false
STRATEGY_VOL_ARB_ENABLED=false
STRATEGY_SENTIMENT_ENABLED=false

# =============================================
# Safety Guardrails (defaults are safe)
# =============================================
GUARDRAIL_SIGNAL_MIN_STD=0.01
GUARDRAIL_MAX_LEVERAGE=1.5
GUARDRAIL_CALIBRATION_TOLERANCE=1e-6
GUARDRAIL_MIN_PROMOTION_SHARPE=0.5
GUARDRAIL_MAX_EXEC_FAILURE_RATE=0.25
GUARDRAIL_EXEC_WINDOW_SECONDS=3600
