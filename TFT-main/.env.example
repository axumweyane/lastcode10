# =============================================
# APEX Trading System — Environment Variables
# =============================================
# Copy to .env and replace all placeholder values with real credentials.
# See .env.template for full configuration options.

# REQUIRED — startup will fail without these
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
DB_PASSWORD=your_secure_password_here
POSTGRES_PASSWORD=your_secure_password_here

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tft_trading
DB_USER=tft_user
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tft_trading
POSTGRES_USER=tft_user

# API Keys (optional — needed for data ingestion)
POLYGON_API_KEY=your_polygon_api_key_here
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# Infrastructure
ALPACA_BASE_URL=https://paper-api.alpaca.markets
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
REDIS_URL=redis://localhost:6379

# Docker Compose (required for docker-compose up)
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here

# Notifications (optional)
DISCORD_WEBHOOK_URL=
EMAIL_PASSWORD=

# Environment
ENV=development
DEBUG=true
