{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Per-Strategy Signal Contribution",
      "description": "Stacked area chart showing each strategy's signal score contribution over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 40,
            "stacking": { "mode": "normal", "group": "A" },
            "lineWidth": 1,
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "apex_signal_score{symbol=~\"$symbol\"}",
          "legendFormat": "{{symbol}} ({{direction}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Strategy Weights (Fixed vs Bayesian)",
      "description": "Line chart comparing fixed and Bayesian ensemble weights per strategy",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 0,
            "lineWidth": 2,
            "spanNulls": false
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "apex_strategy_weight{strategy_name=~\"$strategy\", weight_type=\"fixed\"}",
          "legendFormat": "{{strategy_name}} (fixed)",
          "refId": "A"
        },
        {
          "expr": "apex_strategy_weight{strategy_name=~\"$strategy\", weight_type=\"bayesian\"}",
          "legendFormat": "{{strategy_name}} (bayesian)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Ensemble Confidence Distribution",
      "description": "Histogram of ensemble signal confidence values across all symbols",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "bucketSize": 0.1,
        "combine": false,
        "fillOpacity": 80,
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "rate(apex_ensemble_confidence_bucket[$__rate_interval])",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 4,
      "title": "Market Regime State",
      "description": "Current regime classification, volatility state, and trend state",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "calm": { "text": "CALM", "color": "green" } } },
            { "type": "value", "options": { "volatile": { "text": "VOLATILE", "color": "red" } } },
            { "type": "value", "options": { "trending": { "text": "TRENDING", "color": "blue" } } },
            { "type": "value", "options": { "choppy": { "text": "CHOPPY", "color": "orange" } } }
          ],
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "vertical"
      },
      "targets": [
        {
          "expr": "apex_regime_state_info",
          "legendFormat": "regime={{regime}} vol={{volatility}} trend={{trend}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Pipeline Duration (P50 / P99)",
      "description": "Pipeline execution latency percentiles over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "P50" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(apex_pipeline_duration_seconds_bucket[$__rate_interval]))",
          "legendFormat": "P99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(apex_pipeline_duration_seconds_bucket[$__rate_interval]))",
          "legendFormat": "P50",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Portfolio Drawdown + VaR / CVaR",
      "description": "Current portfolio drawdown with VaR-99 and CVaR-95 risk thresholds",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 0,
            "lineWidth": 2,
            "spanNulls": false,
            "thresholdsStyle": { "mode": "line" }
          },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.10 },
              { "color": "red", "value": 0.20 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "VaR-99" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CVaR-95" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [5, 5] } },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "apex_risk_drawdown",
          "legendFormat": "Drawdown",
          "refId": "A"
        },
        {
          "expr": "apex_risk_var_99",
          "legendFormat": "VaR-99",
          "refId": "B"
        },
        {
          "expr": "apex_risk_cvar_95",
          "legendFormat": "CVaR-95",
          "refId": "C"
        }
      ]
    },
    {
      "id": 7,
      "title": "VWAP Slippage by Symbol",
      "description": "Average execution slippage in basis points per symbol",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "axisCenteredZero": true,
            "fillOpacity": 80,
            "gradientMode": "scheme"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" },
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "expr": "rate(apex_execution_slippage_bps_sum{symbol=~\"$symbol\"}[$__rate_interval]) / rate(apex_execution_slippage_bps_count{symbol=~\"$symbol\"}[$__rate_interval])",
          "legendFormat": "{{symbol}} (bps)",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 8,
      "title": "Strategy Correlation Heatmap",
      "description": "Pairwise strategy weight correlation heatmap — high correlation (>0.85) triggers weight reduction",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": { "type": "linear" }
          }
        },
        "overrides": []
      },
      "options": {
        "calculate": true,
        "calculation": { "xBuckets": { "mode": "size" }, "yBuckets": { "mode": "size" } },
        "color": {
          "mode": "scheme",
          "scheme": "RdYlGn",
          "fill": "dark-orange",
          "reverse": true,
          "exponent": 0.5
        },
        "yAxis": { "axisPlacement": "left" },
        "cellGap": 1,
        "showValue": "auto",
        "tooltip": { "show": true, "yHistogram": false },
        "legend": { "show": true }
      },
      "targets": [
        {
          "expr": "apex_strategy_weight{weight_type=\"bayesian\"}",
          "legendFormat": "{{strategy_name}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["apex", "trading", "ensemble"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(apex_signal_score, symbol)",
        "hide": 0,
        "includeAll": true,
        "label": "Symbol",
        "multi": true,
        "name": "symbol",
        "query": "label_values(apex_signal_score, symbol)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(apex_strategy_weight, strategy_name)",
        "hide": 0,
        "includeAll": true,
        "label": "Strategy",
        "multi": true,
        "name": "strategy",
        "query": "label_values(apex_strategy_weight, strategy_name)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 2,
        "label": "Datasource",
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "timezone": "browser",
  "title": "APEX Ensemble Trading System",
  "uid": "apex-ensemble-dashboard",
  "version": 1
}
